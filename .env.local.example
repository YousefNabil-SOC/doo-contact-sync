# DOO Contact Sync - environment variable template (SAFE TO COMMIT)
# Copy this file to .env.local and fill in the real values there.
# Do NOT put real secret values in this file.

# ---- HubSpot OAuth app (from Phase 0) ----
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=http://localhost:3000/api/oauth/callback

# Space-separated OAuth scopes. "oauth" is required for the OAuth flow.
HUBSPOT_SCOPES=oauth crm.objects.contacts.read crm.objects.contacts.write

# ---- App ----
# Public base URL of this deployment. Must match the URL HubSpot calls for
# webhooks (used to rebuild the canonical URI for v3 signature verification).
APP_BASE_URL=http://localhost:3000

# Optional: base64-encoded 32-byte key to encrypt tokens at rest (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# ---- Database (Supabase Postgres) ----
# DATABASE_URL = pooled connection (used at runtime).
# DIRECT_URL   = direct connection (used by Prisma migrations).
DATABASE_URL=
DIRECT_URL=
